# Entorno virtual — nunca al repo
.venv/

# Requirements completo del venv local — para deploy solo se usa requirements.txt
requirements_dev.txt

# API keys y variables de entorno — NUNCA al repo
.env

# Python
__pycache__/
*.pyc
*.pyo

# Data raw — se regenera con fetch_cities.py
data/raw/

# Datasets grandes — se regeneran con los notebooks (54MB y 60MB)
data/processed/training_dataset.csv
data/processed/training_dataset_enriched.csv

# Artefactos del modelo — versiones antiguas se regeneran
data/processed/model_v2/
# model_v3/ se sube al repo — necesario para ejecutar la app sin reentrenar

# Imágenes generadas por los notebooks
data/processed/*.png

# MLflow
mlruns/
notebooks/mlruns/
models/*.pkl
models/*.bin

# Notebooks de entrenamiento (pesan decenas de MB)
notebooks/01_eda_36ciudades.ipynb
notebooks/02_synthetic_profiles_v2.ipynb
notebooks/02_synthetic_profiles_v3.ipynb
notebooks/03_train_model.ipynb

# HTMLs generados (se regeneran)
data/processed/city_features_eda.html
data/processed/training_dataset_overview.html
# city_features.csv se sube al repo — necesario para ejecutar la app

# HTMLs de presentación y análisis generados (grandes, se regeneran)
data/processed/hitos_proyecto.html
data/processed/nomadoptima_explicacion.html

# Scripts de uso único ya ejecutados
scripts/create_notebook_02v3.py
scripts/create_notebook_03.py

# Configuración local de Claude Code (específica de cada máquina)
.claude/